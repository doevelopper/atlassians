<?xml version="1.0" encoding="UTF-8" ?>
<!--
   ===============================================================================
   Log4CXX Configuration File - Production Ready
   ===============================================================================
   Project: MSF EMS DevContainer
   Purpose: Comprehensive logging configuration for C++ application using log4cxx

   This configuration provides:
   - Console appender for immediate feedback
   - Rolling file appenders for persistent logs with size/time-based rotation
   - Socket appender for remote logging aggregation
   - Syslog appender for system-level integration
   - Hierarchical logger configuration based on package structure

   For log4cxx documentation, see:
   https://logging.apache.org/log4cxx/latest_stable/
   ===============================================================================
-->

<log4j:configuration xmlns:log4j="http://jakarta.apache.org/log4j/"
                     threshold="all"
                     debug="false">

    <!-- ========================================================================
         CONSOLE APPENDER - For development and immediate feedback
         ======================================================================== -->
    <appender name="CONSOLE" class="org.apache.log4j.ConsoleAppender">
        <param name="Target" value="System.out"/>
        <param name="Threshold" value="INFO"/>
        <param name="Encoding" value="UTF-8"/>

        <layout class="org.apache.log4j.PatternLayout">
            <!-- Pattern: [LEVEL] timestamp (logger) thread (location) | message -->
            <param name="ConversionPattern"
                   value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%-5p] [%t] %c{2} - %m%n"/>
        </layout>

        <!-- Filter to reduce noise in console - only INFO and above -->
        <filter class="org.apache.log4j.varia.LevelRangeFilter">
            <param name="LevelMin" value="INFO"/>
            <param name="LevelMax" value="FATAL"/>
            <param name="AcceptOnMatch" value="true"/>
        </filter>
    </appender>

    <!-- ========================================================================
         ROLLING FILE APPENDER - Main application log with size-based rotation
         ======================================================================== -->
    <appender name="ROLLING_FILE" class="org.apache.log4j.RollingFileAppender">
        <param name="File" value="logs/application.log"/>
        <param name="Append" value="true"/>
        <param name="MaxFileSize" value="10MB"/>
        <param name="MaxBackupIndex" value="10"/>
        <param name="Threshold" value="DEBUG"/>
        <param name="Encoding" value="UTF-8"/>

        <layout class="org.apache.log4j.PatternLayout">
            <param name="ConversionPattern"
                   value="%d{ISO8601} [%-5p] [%t] %c{3} (%F:%L) - %m%n"/>
        </layout>
    </appender>

    <!-- ========================================================================
         DAILY ROLLING FILE APPENDER - Time-based rotation for long-term logs
         ======================================================================== -->
    <appender name="DAILY_ROLLING_FILE" class="org.apache.log4j.DailyRollingFileAppender">
        <param name="File" value="logs/application-daily.log"/>
        <param name="Append" value="true"/>
        <param name="Threshold" value="INFO"/>
        <param name="Encoding" value="UTF-8"/>

        <!-- Roll over at midnight each day -->
        <param name="DatePattern" value="'.'yyyy-MM-dd"/>

        <layout class="org.apache.log4j.PatternLayout">
            <param name="ConversionPattern"
                   value="%d{ISO8601} %-5p [%c] (%t) %m%n"/>
        </layout>
    </appender>

    <!-- ========================================================================
         ERROR LOG FILE - Dedicated file for errors and fatal messages
         ======================================================================== -->
    <appender name="ERROR_FILE" class="org.apache.log4j.RollingFileAppender">
        <param name="File" value="logs/errors.log"/>
        <param name="Append" value="true"/>
        <param name="MaxFileSize" value="5MB"/>
        <param name="MaxBackupIndex" value="20"/>
        <param name="Encoding" value="UTF-8"/>

        <layout class="org.apache.log4j.PatternLayout">
            <param name="ConversionPattern"
                   value="%d{ISO8601} [%-5p] %c{3} %t%n  Location: %F:%L%n  Message: %m%n  %n"/>
        </layout>

        <!-- Only log ERROR and FATAL levels -->
        <filter class="org.apache.log4j.varia.LevelRangeFilter">
            <param name="LevelMin" value="ERROR"/>
            <param name="LevelMax" value="FATAL"/>
            <param name="AcceptOnMatch" value="true"/>
        </filter>
        <filter class="org.apache.log4j.varia.DenyAllFilter"/>
    </appender>

    <!-- ========================================================================
         DEBUG LOG FILE - Detailed debugging information
         ======================================================================== -->
    <appender name="DEBUG_FILE" class="org.apache.log4j.RollingFileAppender">
        <param name="File" value="logs/debug.log"/>
        <param name="Append" value="true"/>
        <param name="MaxFileSize" value="20MB"/>
        <param name="MaxBackupIndex" value="5"/>
        <param name="Encoding" value="UTF-8"/>

        <layout class="org.apache.log4j.PatternLayout">
            <param name="ConversionPattern"
                   value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%-5p] [%-15.15t] %c{4} (%F:%L)%n    %m%n"/>
        </layout>

        <!-- Only log DEBUG and TRACE levels -->
        <filter class="org.apache.log4j.varia.LevelRangeFilter">
            <param name="LevelMin" value="TRACE"/>
            <param name="LevelMax" value="DEBUG"/>
            <param name="AcceptOnMatch" value="true"/>
        </filter>
        <filter class="org.apache.log4j.varia.DenyAllFilter"/>
    </appender>

    <!-- ========================================================================
         SOCKET APPENDER - For remote logging to centralized log server
         ======================================================================== -->
    <appender name="SOCKET" class="org.apache.log4j.net.SocketAppender">
        <param name="RemoteHost" value="localhost"/>
        <param name="Port" value="4560"/>
        <param name="ReconnectionDelay" value="10000"/>
        <param name="Threshold" value="WARN"/>

        <!-- Socket appender serializes LoggingEvent objects, no layout needed -->
        <!-- To enable, uncomment and configure with your log server details -->
        <!-- For production, consider using a load balancer or multiple hosts -->
    </appender>

    <!-- ========================================================================
         SYSLOG APPENDER - Integration with system logging facility
         ======================================================================== -->
    <appender name="SYSLOG" class="org.apache.log4j.net.SyslogAppender">
        <param name="SyslogHost" value="localhost"/>
        <param name="Facility" value="LOCAL7"/>
        <param name="Threshold" value="INFO"/>
        <param name="FacilityPrinting" value="true"/>

        <layout class="org.apache.log4j.PatternLayout">
            <param name="ConversionPattern"
                   value="msf-ems-app: [%-5p] %c{2} - %m"/>
        </layout>

        <!-- For production deployment:
             - Adjust SyslogHost to your syslog server
             - Consider using rsyslog or syslog-ng for log aggregation
             - Facility can be LOCAL0-LOCAL7 based on your syslog configuration
        -->
    </appender>

    <!-- ========================================================================
         ASYNC APPENDER - Buffered asynchronous logging for performance
         ======================================================================== -->
    <appender name="ASYNC" class="org.apache.log4j.AsyncAppender">
        <param name="BufferSize" value="256"/>
        <param name="Blocking" value="false"/>

        <!-- Forward to multiple appenders asynchronously -->
        <appender-ref ref="ROLLING_FILE"/>
        <appender-ref ref="DAILY_ROLLING_FILE"/>

        <!-- Async wrapper improves performance by decoupling logging from main thread -->
    </appender>

    <!-- ========================================================================
         PERFORMANCE LOG - Dedicated log for performance metrics
         ======================================================================== -->
    <appender name="PERFORMANCE_FILE" class="org.apache.log4j.RollingFileAppender">
        <param name="File" value="logs/performance.log"/>
        <param name="Append" value="true"/>
        <param name="MaxFileSize" value="10MB"/>
        <param name="MaxBackupIndex" value="10"/>
        <param name="Encoding" value="UTF-8"/>

        <layout class="org.apache.log4j.PatternLayout">
            <param name="ConversionPattern"
                   value="%d{ISO8601},%m%n"/>
        </layout>
    </appender>

    <!-- ========================================================================
         SECURITY AUDIT LOG - Dedicated log for security-related events
         ======================================================================== -->
    <appender name="SECURITY_AUDIT" class="org.apache.log4j.DailyRollingFileAppender">
        <param name="File" value="logs/security-audit.log"/>
        <param name="Append" value="true"/>
        <param name="DatePattern" value="'.'yyyy-MM-dd"/>
        <param name="Encoding" value="UTF-8"/>

        <layout class="org.apache.log4j.PatternLayout">
            <param name="ConversionPattern"
                   value="%d{ISO8601} [SECURITY] %c - %m%n"/>
        </layout>
    </appender>

    <!-- ========================================================================
         LOGGER CONFIGURATIONS - Hierarchical logger settings
         ======================================================================== -->

    <!-- Root package logger -->
    <logger name="com.github.doevelopper.premisses">
        <level value="INFO"/>
    </logger>

    <!-- Licensing module - important for production -->
    <logger name="com.github.doevelopper.premisses.licensing">
        <level value="INFO"/>
        <!-- In production, might want WARN to reduce log volume -->
    </logger>

    <!-- Launcher/Application module -->
    <logger name="com.github.doevelopper.premisses.launcher">
        <level value="INFO"/>
    </logger>

    <!-- Logging framework itself - reduce verbosity -->
    <logger name="com.github.doevelopper.premisses.logging">
        <level value="WARN"/>
    </logger>

    <!-- Triada error handling - detailed logging recommended -->
    <logger name="com.github.doevelopper.premisses.triada">
        <level value="DEBUG"/>
        <appender-ref ref="ERROR_FILE"/>
    </logger>

    <!-- Security/authentication related - audit trail -->
    <logger name="com.github.doevelopper.premisses.security" additivity="false">
        <level value="INFO"/>
        <appender-ref ref="SECURITY_AUDIT"/>
        <appender-ref ref="CONSOLE"/>
    </logger>

    <!-- Performance monitoring logger -->
    <logger name="com.github.doevelopper.premisses.performance" additivity="false">
        <level value="INFO"/>
        <appender-ref ref="PERFORMANCE_FILE"/>
    </logger>

    <!-- Third-party library loggers - typically set to WARN to reduce noise -->
    <logger name="org.apache">
        <level value="WARN"/>
    </logger>

    <!-- ========================================================================
         ROOT LOGGER - Default configuration for all loggers
         ======================================================================== -->
    <root>
        <priority value="DEBUG"/>

        <!-- Production appenders (always enabled) -->
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="ASYNC"/>
        <appender-ref ref="ERROR_FILE"/>

        <!-- Development/Debug appenders (disable in production if needed) -->
        <appender-ref ref="DEBUG_FILE"/>

        <!-- Remote/System appenders (configure and uncomment for production) -->
        <!-- <appender-ref ref="SOCKET"/> -->
        <!-- <appender-ref ref="SYSLOG"/> -->
    </root>

    <!-- ========================================================================
         PRODUCTION DEPLOYMENT NOTES
         ========================================================================

         1. LOG ROTATION:
            - Implement external log rotation (logrotate on Linux)
            - Archive old logs to long-term storage
            - Monitor disk space usage

         2. PERFORMANCE:
            - Use ASYNC appender for high-throughput scenarios
            - Adjust buffer sizes based on load testing
            - Consider separate log volumes for I/O performance

         3. SECURITY:
            - Ensure log files have appropriate permissions (640)
            - Rotate and encrypt sensitive logs
            - Implement log retention policy

         4. MONITORING:
            - Set up alerts for ERROR and FATAL log entries
            - Monitor log file sizes and rotation
            - Integrate with centralized logging (ELK, Splunk, etc.)

         5. ENVIRONMENT-SPECIFIC:
            - Development: Enable DEBUG_FILE, set levels to DEBUG
            - Staging: Profile with PERFORMANCE_FILE, set to INFO
            - Production: Disable DEBUG_FILE, set to WARN/ERROR, enable SOCKET/SYSLOG

         6. LOG LEVELS BY ENVIRONMENT:
            - Development: DEBUG or TRACE for root logger
            - Staging: INFO for root logger
            - Production: WARN for root logger, INFO for critical modules

         ======================================================================== -->

</log4j:configuration>