###############################################################################
# Set default behavior to automatically normalize line endings.
###############################################################################
* text eol=lf

###############################################################################
# Denote all files that are truly binary and should not be modified.
###############################################################################
*.psd binary
*.ai binary
*.png binary
*.gif binary
*.jpg binary
*.jpeg binary
*.ico binary
*.zip binary
*.jar binary
*.war binary
*.ear binary
*.pdf binary
*.doc binary
*.docx binary
*.xls binary
*.xlsx binary
*.ppt binary
*.pptx binary
*.mp3 binary
*.mp4 binary
# List generated files
# - prevents GitHub from showing deltas during code review
# - informs the rules_lint formatter not to apply formatting rules
maven_install.json     linguist-generated=true
githooks/pre-commit    rules-lint-ignored=true
