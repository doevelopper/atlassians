# =============================================================================
# CI Tool Versions — single source of truth
# Keep in sync with .devcontainer/cpp/Dockerfile ARG declarations.
# Reference these values in CI pipeline YAML files via:
#   GitHub Actions : env: section or ${{ env.VAR }}
#   GitLab CI      : variables: section or $VAR
# =============================================================================

# --- Base OS ---
UBUNTU_VERSION=24.04
UBUNTU_DIGEST=sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

# --- C++ Toolchain (mirrors devcontainer) ---
GCC_VERSION=14
CLANG_VERSION=20
# CMake is installed via pip (cmake package) to get a newer version than Ubuntu apt provides
CMAKE_PIP_VERSION=4.3.0
CPM_VERSION=0.42.1

# --- Build acceleration ---
CCACHE_VERSION=4.13.1

# --- Cross-compilation (optional, used in devcontainer) ---
XWIN_VERSION=0.8.0

# --- Shell testing (BATS) ---
BATS_CORE_VERSION=1.13.0
BATS_SUPPORT_VERSION=0.3.0
BATS_ASSERT_VERSION=2.2.4

# --- Security scanners (used by .docker/scanner) ---
# TODO: bump these when releasing a new image;
#       verify SHA256 checksums from official release pages before updating.
TRIVY_VERSION=0.58.1
HADOLINT_VERSION=2.12.0
SHELLCHECK_VERSION=0.10.0
SEMGREP_VERSION=1.100.0
GRYPE_VERSION=0.88.0
SYFT_VERSION=1.18.0
