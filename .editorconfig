root = true

[*]
charset = utf-8
insert_final_newline = true
end_of_line = lf
indent_style = space
indent_size = 2
max_line_length = 80

[Makefile]
indent_style = tab
indent_size = 8

[*.md]
max_line_length = off


[*.{kt,kts}]
insert_final_newline = true
kotlin_imports_layout = *,java.**,javax.**,kotlin.**,^
ij_kotlin_imports_layout = *,java.**,javax.**,kotlin.**,^
indent_size = 2
indent_style = space
max_line_length = 200
ktlint_ignore_back_ticked_identifier = false
ij_kotlin_packages_to_use_import_on_demand = java.util.*,kotlinx.android.synthetic.**
